<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:backgroundTint="#F5EFFB"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text=""
            app:cornerRadius="24dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            app:iconTint="#7B1FA2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvScanTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Scan Food"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="#111111"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTakePhoto"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="34dp"
            android:text="Take Photo and Analyze"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8A1DB5"
            app:cornerRadius="16dp"
            app:icon="@drawable/outline_photo_camera_24"
            app:iconTint="#FFFFFF"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconSize="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardQuantity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:visibility="gone"
            android:backgroundTint="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#EAEAEA"
            app:layout_constraintTop_toBottomOf="@id/btnTakePhoto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvQuantityTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Adjust quantity"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#111111"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvQuantityHint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="AI estimates the grams. You can correct them before saving."
                    android:textSize="13sp"
                    android:textColor="#777777"
                    app:layout_constraintTop_toBottomOf="@id/tvQuantityTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilGrams"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Grams"
                    app:boxStrokeColor="#8A1DB5"
                    app:hintTextColor="#8A1DB5"
                    app:layout_constraintTop_toBottomOf="@id/tvQuantityHint"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etGrams"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textSize="15sp"
                        android:textColor="#111111" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveToMyFoods"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="Save to My Foods"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#7B1FA2"
                    android:backgroundTint="#F5EFFB"
                    android:enabled="false"
                    android:alpha="0.5"
                    app:cornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#D7BDEB"
                    app:layout_constraintTop_toBottomOf="@id/tilGrams"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:backgroundTint="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp"
            app:strokeWidth="1dp"
            app:strokeColor="#EAEAEA"
            app:layout_constraintTop_toBottomOf="@id/cardQuantity"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvResultTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No food analyzed yet"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#111111" />

                <TextView
                    android:id="@+id/tvResultSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Take a photo and the app will analyze it automatically."
                    android:textSize="13sp"
                    android:textColor="#777777" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:background="#EEEEEE" />

                <TextView
                    android:id="@+id/tvFoodLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Food"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#8A1DB5" />

                <TextView
                    android:id="@+id/tvFoodValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="-"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#F5EFFB"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Quantity"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#777777" />

                        <TextView
                            android:id="@+id/tvQuantityValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="-"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#111111" />

                    </LinearLayout>

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#F5EFFB"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Calories"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#777777" />

                        <TextView
                            android:id="@+id/tvCaloriesValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="-"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#111111" />

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Macros"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvProteinValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:background="#F7F7F7"
                        android:padding="10dp"
                        android:text="Protein\n-"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333" />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvCarbsValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:background="#F7F7F7"
                        android:padding="10dp"
                        android:text="Carbs\n-"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333" />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvFatValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:background="#F7F7F7"
                        android:padding="10dp"
                        android:text="Fat\n-"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#333333" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvInsightLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Nutrition Insight"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />

                <TextView
                    android:id="@+id/tvInsightValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5EFFB"
                    android:padding="12dp"
                    android:text="Nutrition insight will appear here after analysis."
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:lineSpacingExtra="3dp" />

                <TextView
                    android:id="@+id/tvConfidenceValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Confidence: -"
                    android:textSize="13sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/tvNoteValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Nutrition values will appear here after analysis."
                    android:textSize="13sp"
                    android:textColor="#777777"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveFood"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:text="Save Food"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B1FA2"
            android:enabled="false"
            android:alpha="0.5"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardResult"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>