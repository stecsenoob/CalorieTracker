<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_chevron_right"
        android:rotation="180"
        app:tint="#7E57C2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFood"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:strokeWidth="1dp"
        app:strokeColor="#EEEAF7"
        app:cardBackgroundColor="#F4ECFB"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvFoodTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apple"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/tvFoodPortion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100g"
                android:textSize="14sp"
                android:textColor="#777777"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvFoodCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="95 kcal"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#7E57C2"
                android:background="@drawable/bg_calorie_badge"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="12dp" />

            <HorizontalScrollView
                android:id="@+id/macrosScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/rowMacros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvProtein"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="7dp"
                        android:background="@drawable/bg_chip_protein"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="Protein: 0.5g"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#111111"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/tvFat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="7dp"
                        android:background="@drawable/bg_chip_fat"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="Fat: 0.3g"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#111111"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/tvCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_carbs"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="Carbs: 25g"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#111111"
                        android:maxLines="1" />

                </LinearLayout>

            </HorizontalScrollView>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPortionCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:hint="Portion count"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxStrokeColor="#D7C9F4"
        app:layout_constraintTop_toBottomOf="@id/cardFood"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPortionCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:text="1"
            android:padding="12dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilGrams"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Grams / ml"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:boxStrokeColor="#D7C9F4"
        app:layout_constraintTop_toBottomOf="@id/tilPortionCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etGrams"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:text="100"
            android:padding="12dp" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddBreakfast"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="Add to Breakfast"
        android:layout_marginTop="16dp"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingVertical="8dp"
        app:cornerRadius="14dp"
        app:backgroundTint="#F0EAFB"
        app:strokeWidth="1dp"
        app:strokeColor="#E6E0F2"
        android:textColor="#7E57C2"
        app:layout_constraintTop_toBottomOf="@id/tilGrams"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddLunch"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="Add to Lunch"
        android:layout_marginTop="10dp"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingVertical="8dp"
        app:cornerRadius="14dp"
        app:backgroundTint="#F0EAFB"
        app:strokeWidth="1dp"
        app:strokeColor="#E6E0F2"
        android:textColor="#7E57C2"
        app:layout_constraintTop_toBottomOf="@id/btnAddBreakfast"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddDinner"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="Add to Dinner"
        android:layout_marginTop="10dp"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingVertical="8dp"
        app:cornerRadius="14dp"
        app:backgroundTint="#F0EAFB"
        app:strokeWidth="1dp"
        app:strokeColor="#E6E0F2"
        android:textColor="#7E57C2"
        app:layout_constraintTop_toBottomOf="@id/btnAddLunch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddSnacks"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:text="Add to Snacks"
        android:layout_marginTop="10dp"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingVertical="8dp"
        app:cornerRadius="14dp"
        app:backgroundTint="#F0EAFB"
        app:strokeWidth="1dp"
        app:strokeColor="#E6E0F2"
        android:textColor="#7E57C2"
        app:layout_constraintTop_toBottomOf="@id/btnAddDinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>