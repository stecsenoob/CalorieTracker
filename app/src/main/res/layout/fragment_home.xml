<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ================= BREAKFAST ================= -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBreakfast"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#EAEAEA"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/ivBreakfast"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_breakfast"
                app:tint="#7E57C2"
                android:contentDescription="@null"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <ImageView
                android:id="@+id/ivBreakfastChevron"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="#B0B0B0"
                android:contentDescription="@null"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tvBreakfastTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Breakfast"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111111"
                app:layout_constraintStart_toEndOf="@id/ivBreakfast"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivBreakfastChevron"/>

            <TextView
                android:id="@+id/tvBreakfastSub"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="2dp"
                android:text="0 items • 0 kcal"
                android:textSize="13sp"
                android:textColor="#777777"
                app:layout_constraintStart_toEndOf="@id/ivBreakfast"
                app:layout_constraintTop_toBottomOf="@id/tvBreakfastTitle"
                app:layout_constraintEnd_toStartOf="@id/ivBreakfastChevron"/>

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="10dp"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintStart_toEndOf="@id/ivBreakfast"
                app:layout_constraintTop_toBottomOf="@id/tvBreakfastSub"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/rowBreakfastChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <TextView
                        android:id="@+id/tvBreakfastKcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 kcal"
                        android:maxLines="1"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_chip_kcal"/>

                    <TextView
                        android:id="@+id/tvBreakfastP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="Pro 0.0g"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#1B5E20"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_chip_protein"/>

                    <TextView
                        android:id="@+id/tvBreakfastF"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="Fat 0.0g"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#E65100"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_chip_fat"/>

                    <TextView
                        android:id="@+id/tvBreakfastC"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="Carb 0.0g"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#0D47A1"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_chip_carbs"/>
                </LinearLayout>
            </HorizontalScrollView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

