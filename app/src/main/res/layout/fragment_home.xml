                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <TextView
                        android:id="@+id/tvLunchKcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 kcal"
                        android:maxLines="1"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_chip_kcal"/>

                    <TextView
                        android:id="@+id/tvLunchP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="Pro 0.0g"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#1B5E20"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_chip_protein"/>

                    <TextView
                        android:id="@+id/tvLunchF"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="Fat 0.0g"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#E65100"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_chip_fat"/>

                    <TextView
                        android:id="@+id/tvLunchC"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:text="Carb 0.0g"
                        android:maxLines="1"
                        android:textSize="11sp"
                        android:textColor="#0D47A1"
