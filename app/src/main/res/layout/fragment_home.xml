<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:backgroundTint="#F5EFFB"
        android:contentDescription="Log out"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        app:cornerRadius="21dp"
        app:icon="@drawable/ic_logout_24"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="22dp"
        app:iconTint="#7B1FA2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="56dp"
        android:paddingEnd="56dp"
        android:text="CalorieTracker"
        android:textColor="#111111"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textAlignment="center"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnLogout"
        app:layout_constraintBottom_toBottomOf="@id/btnLogout" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnLogout"
        app:layout_constraintBottom_toTopOf="@id/btnOpenScanDialog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- ================= BREAKFAST ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBreakfast"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EAEAEA"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/ivBreakfast"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_breakfast"
                        android:contentDescription="@null"
                        app:tint="#7E57C2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <ImageView
                        android:id="@+id/ivBreakfastChevron"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="#B0B0B0"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                        android:id="@+id/tvBreakfastTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Breakfast"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        app:layout_constraintStart_toEndOf="@id/ivBreakfast"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivBreakfastChevron"/>

                    <TextView
                        android:id="@+id/tvBreakfastSub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="2dp"
                        android:text="0 items • 0 kcal"
                        android:textSize="13sp"
                        android:textColor="#777777"
                        app:layout_constraintStart_toEndOf="@id/ivBreakfast"
                        app:layout_constraintTop_toBottomOf="@id/tvBreakfastTitle"
                        app:layout_constraintEnd_toStartOf="@id/ivBreakfastChevron"/>

                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none"
                        android:overScrollMode="never"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        app:layout_constraintStart_toEndOf="@id/ivBreakfast"
                        app:layout_constraintTop_toBottomOf="@id/tvBreakfastSub"
                        app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout
                            android:id="@+id/rowBreakfastChips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <TextView
                                android:id="@+id/tvBreakfastKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kcal"
                                android:maxLines="1"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="5dp"
                                android:background="@drawable/bg_chip_kcal"/>

                            <TextView
                                android:id="@+id/tvBreakfastP"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Protein 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#1B5E20"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_protein"/>

                            <TextView
                                android:id="@+id/tvBreakfastF"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="7dp"
                                android:text="Fat 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#E65100"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_fat"/>

                            <TextView
                                android:id="@+id/tvBreakfastC"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="7dp"
                                android:text="Carbs 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#0D47A1"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_carbs"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= LUNCH ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLunch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EAEAEA"
                app:layout_constraintTop_toBottomOf="@id/cardBreakfast"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/ivLunch"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/outline_food_bank_24"
                        android:contentDescription="@null"
                        app:tint="#7E57C2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <ImageView
                        android:id="@+id/ivLunchChevron"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="#B0B0B0"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                        android:id="@+id/tvLunchTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Lunch"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        app:layout_constraintStart_toEndOf="@id/ivLunch"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivLunchChevron"/>

                    <TextView
                        android:id="@+id/tvLunchSub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="2dp"
                        android:text="0 items • 0 kcal"
                        android:textSize="13sp"
                        android:textColor="#777777"
                        app:layout_constraintStart_toEndOf="@id/ivLunch"
                        app:layout_constraintTop_toBottomOf="@id/tvLunchTitle"
                        app:layout_constraintEnd_toStartOf="@id/ivLunchChevron"/>

                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none"
                        android:overScrollMode="never"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        app:layout_constraintStart_toEndOf="@id/ivLunch"
                        app:layout_constraintTop_toBottomOf="@id/tvLunchSub"
                        app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout
                            android:id="@+id/rowLunchChips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <TextView
                                android:id="@+id/tvLunchKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kcal"
                                android:maxLines="1"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="5dp"
                                android:background="@drawable/bg_chip_kcal"/>

                            <TextView
                                android:id="@+id/tvLunchP"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Protein 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#1B5E20"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_protein"/>

                            <TextView
                                android:id="@+id/tvLunchF"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="7dp"
                                android:text="Fat 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#E65100"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_fat"/>

                            <TextView
                                android:id="@+id/tvLunchC"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="7dp"
                                android:text="Carbs 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#0D47A1"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_carbs"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= DINNER ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EAEAEA"
                app:layout_constraintTop_toBottomOf="@id/cardLunch"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/ivDinner"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/outline_meal_dinner_24"
                        android:contentDescription="@null"
                        app:tint="#7E57C2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <ImageView
                        android:id="@+id/ivDinnerChevron"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="#B0B0B0"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                        android:id="@+id/tvDinnerTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Dinner"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        app:layout_constraintStart_toEndOf="@id/ivDinner"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivDinnerChevron"/>

                    <TextView
                        android:id="@+id/tvDinnerSub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="2dp"
                        android:text="0 items • 0 kcal"
                        android:textSize="13sp"
                        android:textColor="#777777"
                        app:layout_constraintStart_toEndOf="@id/ivDinner"
                        app:layout_constraintTop_toBottomOf="@id/tvDinnerTitle"
                        app:layout_constraintEnd_toStartOf="@id/ivDinnerChevron"/>

                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none"
                        android:overScrollMode="never"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        app:layout_constraintStart_toEndOf="@id/ivDinner"
                        app:layout_constraintTop_toBottomOf="@id/tvDinnerSub"
                        app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout
                            android:id="@+id/rowDinnerChips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <TextView
                                android:id="@+id/tvDinnerKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kcal"
                                android:maxLines="1"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="5dp"
                                android:background="@drawable/bg_chip_kcal"/>

                            <TextView
                                android:id="@+id/tvDinnerP"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Protein 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#1B5E20"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_protein"/>

                            <TextView
                                android:id="@+id/tvDinnerF"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="7dp"
                                android:text="Fat 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#E65100"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_fat"/>

                            <TextView
                                android:id="@+id/tvDinnerC"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="7dp"
                                android:text="Carbs 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#0D47A1"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_carbs"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= SNACKS ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSnacks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EAEAEA"
                app:layout_constraintTop_toBottomOf="@id/cardDinner"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/ivSnacks"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/outline_fastfood_24"
                        android:contentDescription="@null"
                        app:tint="#7E57C2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <ImageView
                        android:id="@+id/ivSnacksChevron"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="#B0B0B0"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <TextView
                        android:id="@+id/tvSnacksTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Snacks"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        app:layout_constraintStart_toEndOf="@id/ivSnacks"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivSnacksChevron"/>

                    <TextView
                        android:id="@+id/tvSnacksSub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="2dp"
                        android:text="0 items • 0 kcal"
                        android:textSize="13sp"
                        android:textColor="#777777"
                        app:layout_constraintStart_toEndOf="@id/ivSnacks"
                        app:layout_constraintTop_toBottomOf="@id/tvSnacksTitle"
                        app:layout_constraintEnd_toStartOf="@id/ivSnacksChevron"/>

                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none"
                        android:overScrollMode="never"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        app:layout_constraintStart_toEndOf="@id/ivSnacks"
                        app:layout_constraintTop_toBottomOf="@id/tvSnacksSub"
                        app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout
                            android:id="@+id/rowSnacksChips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <TextView
                                android:id="@+id/tvSnacksKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kcal"
                                android:maxLines="1"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:textColor="#FFFFFF"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="5dp"
                                android:background="@drawable/bg_chip_kcal"/>

                            <TextView
                                android:id="@+id/tvSnacksP"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Protein 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#1B5E20"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_protein"/>

                            <TextView
                                android:id="@+id/tvSnacksF"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="7dp"
                                android:text="Fat 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#E65100"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_fat"/>

                            <TextView
                                android:id="@+id/tvSnacksC"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="7dp"
                                android:text="Carbs 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#0D47A1"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_carbs"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= GRAND TOTAL ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGrandTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:backgroundTint="#F5EFFB"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EAEAEA"
                app:layout_constraintTop_toBottomOf="@id/cardSnacks"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:id="@+id/tvGrandTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Total today"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:scrollbars="none"
                        android:overScrollMode="never"
                        android:requiresFadingEdge="horizontal"
                        android:fadingEdgeLength="24dp"
                        app:layout_constraintTop_toBottomOf="@id/tvGrandTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout
                            android:id="@+id/rowGrandChips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp">

                            <TextView
                                android:id="@+id/tvGrandKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kcal"
                                android:maxLines="1"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:textColor="#FFFFFF"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_kcal"/>

                            <TextView
                                android:id="@+id/tvGrandP"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Protein 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#1B5E20"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_protein"/>

                            <TextView
                                android:id="@+id/tvGrandF"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Fat 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#E65100"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_fat"/>

                            <TextView
                                android:id="@+id/tvGrandC"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Carbs 0.0g"
                                android:maxLines="1"
                                android:textSize="12sp"
                                android:textColor="#0D47A1"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_chip_carbs"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenScanDialog"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_marginBottom="18dp"
        android:text="+"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="32sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#7B1FA2"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:elevation="8dp"
        app:cornerRadius="34dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>