                    <TextView
                        android:id="@+id/tvGrandC"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Carb 0.0g"
                        android:maxLines="1"
                        android:textSize="12sp"
                        android:textColor="#0D47A1"
