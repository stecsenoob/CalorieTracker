<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add to Meal"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#111111"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvDialogSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Choose where you want to save this food."
            android:textSize="14sp"
            android:textColor="#777777"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMealBreakfast"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:text="Breakfast"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#7B1FA2"
            android:backgroundTint="#F5EFFB"
            app:cornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="#D7BDEB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMealLunch"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:text="Lunch"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#7B1FA2"
            android:backgroundTint="#F5EFFB"
            app:cornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="#D7BDEB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMealDinner"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:text="Dinner"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#7B1FA2"
            android:backgroundTint="#F5EFFB"
            app:cornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="#D7BDEB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMealSnacks"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:text="Snacks"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#7B1FA2"
            android:backgroundTint="#F5EFFB"
            app:cornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="#D7BDEB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMealCancel"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#777777"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="16dp"
            app:strokeWidth="0dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>